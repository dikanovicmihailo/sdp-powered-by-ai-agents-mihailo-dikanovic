@startuml runtime-happy-path
participant Operator
participant "__main__" as Main
participant InputParser
participant MissionController
participant Rover
participant Plateau

Operator -> Main: stdin
Main -> InputParser: parse()
InputParser --> Main: plateau, [(rover, cmds)]
Main -> MissionController: run_mission(plateau, pairs)
MissionController -> Rover: Rover(init_position)
loop for each command
    MissionController -> Rover: execute(cmd)
    Rover -> Plateau: is_within(x + dx, y + dy)
    Plateau --> Rover: bool
end
MissionController --> Main: [final rovers]
Main -> Operator: stdout (formatted positions)
@enduml
